# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored; `.env.example` is checked in as the template.

# Reddit (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=content-engine by u/yourusername

# YouTube Data API v3 (Google Cloud Console)
YOUTUBE_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Apify (TikTok scraping)
APIFY_API_TOKEN=

# Twitter / X (developer.twitter.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
