# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored; `.env.example` is checked in as the template.

# Reddit — no OAuth needed. We hit public JSON endpoints.
# User-Agent is required and load-bearing — Reddit blocks default httpx UA.
# Format: <app>/<version> by u/<your-reddit-username>
REDDIT_USER_AGENT=content-engine/0.1 by u/yourusername

# YouTube Data API v3 (Google Cloud Console)
YOUTUBE_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Apify (TikTok scraping)
APIFY_API_TOKEN=

# Twitter / X (developer.twitter.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
