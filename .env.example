# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored; `.env.example` is checked in as the template.

# Anthropic — caption / hook generation
ANTHROPIC_API_KEY=

# YouTube Data API v3 — analytics pull for Shorts
# (Same key as before; now used for /metrics, not scraping.)
# Console: https://console.cloud.google.com — enable YouTube Data API v3
YOUTUBE_API_KEY=

# Twitter / X — auto-post + analytics (deferred; Basic tier is $100/mo)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
